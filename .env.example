# Optional ASO runtime settings
# ASO_DB_PATH=/absolute/path/to/aso-db.sqlite
# ASO_AUTH_MODE=auto
# ASO_APPLE_WIDGET_KEY=
# ASO_SIRP_RUBY_ORACLE=0
# ASO_SIRP_USE_RUBY_PROOF=0

# Optional ASO resilience tuning
# ASO_RETRY_MAX_ATTEMPTS=4
# ASO_RETRY_BASE_DELAY_MS=1000
# ASO_RETRY_MAX_DELAY_MS=30000
# ASO_RATE_LIMIT_BASE_DELAY_MS=5000
# ASO_RETRY_JITTER_FACTOR=0.1
# ASO_KEYWORD_ENRICHMENT_CONCURRENCY=4
# ASO_CACHE_TTL_HOURS=24
# ASO_APP_CACHE_TTL_HOURS=168
